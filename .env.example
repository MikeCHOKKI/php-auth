# .env.example — Template des variables d'environnement
# Copier vers .env et renseigner les valeurs réelles
# Ce fichier EST commité. .env ne l'est JAMAIS.

# ==========================================
# Application
# ==========================================
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_PORT=8080

# ==========================================
# Base de données PostgreSQL
# ==========================================
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=php_auth
DB_USERNAME=postgres
DB_PASSWORD=secret

# ==========================================
# JWT RS256 — Clés générées via: openssl genrsa -out keys/private.pem 2048
# ==========================================
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800

# ==========================================
# Sécurité
# ==========================================
# Clé de chiffrement pour données sensibles (générer: openssl rand -hex 32)
ENCRYPTION_KEY=CHANGE_ME_32_CHARS_HEX_STRING

# Rate limiting (requests per minute)
RATE_LIMIT_LOGIN=5
RATE_LIMIT_REFRESH=10

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=debug
LOG_CHANNEL=stdout
