{
  "name": "php-auth/app",
  "description": "Système d'authentification RBAC avec JWT RS256 et rotation de refresh tokens",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "Mike CHOKKI",
      "email": "mikechokki5@gmail.com"
    }
  ],
  "require": {
    "php": "^8.3",
    "firebase/php-jwt": "^6.10",
    "vlucas/phpdotenv": "^5.6",
    "psr/http-message": "^2.0",
    "psr/http-server-handler": "^1.0",
    "psr/http-server-middleware": "^1.0",
    "psr/log": "^3.0",
    "monolog/monolog": "^3.5",
    "ext-pdo": "*",
    "ext-pdo_pgsql": "*",
    "ext-sodium": "*",
    "ext-openssl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.9",
    "phpstan/phpstan": "^1.10",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test-coverage": "phpunit --coverage-html coverage",
    "lint": "phpcs --standard=PSR12 src tests",
    "lint-fix": "phpcbf --standard=PSR12 src tests",
    "analyse": "phpstan analyse src tests --level=8",
    "ci": [
      "@lint",
      "@analyse",
      "@test"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": true,
    "audit": {
      "ignore": [
        "PKSA-y2cr-5h3j-g3ys"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
